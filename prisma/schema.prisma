generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  cpf           String?        @unique
  phone         String?
  password      String?
  googleId      String?      @unique
  role          String         @default("user")
  producerName  String?
  producerBio   String?
  pixKey        String?
  pixKeyType    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  orders        Order[]
  purchases     Purchase[]
  products      Product[]
  earnings      ProducerEarning[]
  affiliate     Affiliate?
  withdrawals   Withdrawal[]
  processedWithdrawals Withdrawal[] @relation("processedWithdrawals")
}

model Product {
  id              String      @id @default(cuid())
  title           String
  description     String
  price           Float
  comparePrice    Float?
  imageUrl        String?
  contentUrl      String?
  contentType     String      @default("video")
  productType     String      @default("course")
  category        String?
  tags            String?
  highlights      String?
  targetAudience  String?
  requirements    String?
  affiliateMaterials String?
  slug            String?     @unique
  installments    Int         @default(1)
  isSubscription  Boolean     @default(false)
  subscriptionDays Int?
  published       Boolean     @default(false)
  producerId      String?
  producer        User?       @relation(fields: [producerId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orders          Order[]
  purchases       Purchase[]
}

model Order {
  id            String        @id @default(cuid())
  userId        String
  productId     String
  amount        Float
  status        String        @default("pending")
  paymentMethod String?
  paymentId     String?
  coupon        String?
  affiliateId   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])
  earnings      ProducerEarning[]
  affiliateSales AffiliateSale[]
}

model Purchase {
  id            String      @id @default(cuid())
  userId        String
  productId     String
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])
}

model Subscription {
  id            String      @id @default(cuid())
  userId        String
  productId     String
  stripeSubId   String      @unique
  status        String      @default("active")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ProducerEarning {
  id            String      @id @default(cuid())
  producerId    String
  orderId       String
  amount        Float
  status        String      @default("pending")
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
  producer      User        @relation(fields: [producerId], references: [id])
  order         Order       @relation(fields: [orderId], references: [id])
}

model Affiliate {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  referralCode  String      @unique
  commissionRate Float      @default(10.0)
  createdAt     DateTime    @default(now())
  sales         AffiliateSale[]
}

model AffiliateSale {
  id            String      @id @default(cuid())
  affiliateId   String
  orderId       String
  commission    Float
  status        String      @default("pending")
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
  affiliate     Affiliate   @relation(fields: [affiliateId], references: [id])
  order         Order       @relation(fields: [orderId], references: [id])
}

model Withdrawal {
  id            String    @id @default(cuid())
  userId        String
  amount        Float     // valor líquido que o usuário recebe
  fee           Float     @default(3.19) // taxa fixa por saque
  grossAmount   Float     // amount + fee (total debitado do saldo)
  type          String    @default("producer") // "producer" | "affiliate"
  pixKey        String
  pixKeyType    String    // "cpf" | "cnpj" | "email" | "phone" | "random"
  status        String    @default("pending") // "pending" | "approved" | "rejected"
  createdAt     DateTime  @default(now())
  processedAt   DateTime?
  processedById String?
  user          User      @relation(fields: [userId], references: [id])
  processedBy   User?     @relation("processedWithdrawals", fields: [processedById], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  role      String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
